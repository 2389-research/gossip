#!/usr/bin/env bash
# ABOUTME: Canonical verification for GOssip: gofmt, go vet, go test.
# ABOUTME: Run before every commit and before claiming any work complete.
set -euo pipefail
cd "$(dirname "$0")/.."

fail=0

unformatted=$(gofmt -l . 2>/dev/null | grep -v '^\.git/' || true)
if [ -n "$unformatted" ]; then
  echo "gofmt needed on:" >&2
  echo "$unformatted" >&2
  fail=1
fi

go vet ./... || fail=1
go test ./... || fail=1

if [ "$fail" -ne 0 ]; then
  echo "check: FAIL" >&2
  exit 1
fi
echo "check: OK"
